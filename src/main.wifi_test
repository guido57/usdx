#include <WiFi.h>
#include "esp_wifi.h"

// --- SETTINGS ---
const char* ssid = "TIM-18373419";
const char* pass = "K9giYCTW4ryRS1MT26oIs7BG";

void WiFiEvent(WiFiEvent_t event, WiFiEventInfo_t info) {
    switch (event) {
        case ARDUINO_EVENT_WIFI_STA_START:
            Serial.println("STA Started");
            break;
        case ARDUINO_EVENT_WIFI_STA_CONNECTED:
            Serial.println("Connected to AP");
            break;
        case ARDUINO_EVENT_WIFI_STA_GOT_IP:
            Serial.print("Got IP: ");
            Serial.println(WiFi.localIP());
            break;
        case ARDUINO_EVENT_WIFI_STA_DISCONNECTED:
            Serial.print("Disconnected. Reason: ");
            Serial.println(info.wifi_sta_disconnected.reason);
            // High frequency of Reason 2 usually means poor power or signal interference
            break;
        default: break;
    }
}

void setup() {
    Serial.begin(115200);
    delay(2000);
    Serial.println("\n--- WiFi Diagnostic Mode ---");

    // 1. Setup Events
    WiFi.onEvent(WiFiEvent);

    // 2. Clean Start
    WiFi.mode(WIFI_STA);
    WiFi.disconnect(true);
    delay(100);

    // 3. CRITICAL: Disable Power Save for S3 stability
    // This ensures the radio never sleeps during the handshake
    esp_wifi_set_ps(WIFI_PS_NONE);

    // 4. Start Connection
    Serial.printf("Connecting to %s...\n", ssid);
    WiFi.begin(ssid, pass);
}

void loop() {
    // Just pulse the status every 5 seconds
    static uint32_t lastCheck = 0;
    if (millis() - lastCheck > 5000) {
        lastCheck = millis();
        if (WiFi.status() == WL_CONNECTED) {
            Serial.printf("Status: Connected | RSSI: %d dBm\n", WiFi.RSSI());
            Serial.printf("[WiFi] Connected to AP MAC (BSSID): %s\n", WiFi.BSSIDstr().c_str());

        } else {
            Serial.println("Status: Searching...");
        }
    }
}